{
  "name": "skyclad-llm-gateway",
  "version": "1.0.0",
  "description": "Multi-tenant LLM gateway for the Skyclad Ventures backend assignment",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "LOG_LEVEL=silent npm run build && LOG_LEVEL=silent node --test dist/tests/unit/*.test.js dist/tests/integration/*.test.js"
  },
  "keywords": [
    "llm",
    "gateway",
    "typescript",
    "express",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "9.6.0",
    "dotenv": "16.4.7",
    "express": "4.22.1",
    "helmet": "7.2.0",
    "pino": "9.5.0",
    "prom-client": "15.1.3",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.11",
    "@types/express": "5.0.0",
    "@types/node": "22.10.7",
    "@types/supertest": "6.0.2",
    "supertest": "7.1.3",
    "tsx": "4.20.6",
    "typescript": "5.7.3"
  }
}
