NODE_ENV=development
PORT=3000
DATABASE_PATH=./data/skyclad-gateway.db
LOG_LEVEL=info

# Real provider keys are optional for local mock-driven testing.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Provider behavior tuning.
PROVIDER_TIMEOUT_MS=15000
PROVIDER_MAX_RETRIES=2
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RESET_TIMEOUT_MS=30000

# Request and cache limits.
MAX_PROMPT_CHARS=200000
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# Demo tenants are inserted on first migration/seed.
SEED_DEMO_DATA=true
